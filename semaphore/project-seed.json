{
  "meta": {
    "name": "Orka Engine Orchestration",
    "alert": false,
    "max_parallel_tasks": 0,
    "type": ""
  },
  "keys": [
    {
      "name": "Mac Hosts SSH",
      "type": "login_password"
    }
  ],
  "repositories": [
    {
      "name": "Local Playbooks",
      "git_url": "/opt/orka",
      "git_branch": "",
      "ssh_key": "Mac Hosts SSH"
    }
  ],
  "inventories": [
    {
      "name": "Dev Inventory",
      "type": "file",
      "inventory": "dev/inventory",
      "ssh_key": "Mac Hosts SSH",
      "become_key": "Mac Hosts SSH"
    }
  ],
  "environments": [
    {
      "name": "Default",
      "json": "{}",
      "env": null,
      "password": null
    }
  ],
  "templates": [
    {
      "name": "Deploy VM",
      "app": "ansible",
      "playbook": "deploy.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "vm_name",
          "title": "VM Name",
          "required": true,
          "type": "",
          "description": "Name of the VM to deploy"
        },
        {
          "name": "vm_image",
          "title": "VM Image",
          "type": "string",
          "required": true,
          "description": "An OCI URL for an Orka VM image"
        },
        {
          "name": "cpu",
          "title": "CPU Cores",
          "type": "integer",
          "required": false,
          "default_value": "2",
          "description": "Number of CPU cores to allocate"
        },
        {
          "name": "memory",
          "title": "Memory (MB)",
          "type": "integer",
          "required": false,
          "default_value": "4096",
          "description": "Amount of memory in MB to allocate"
        },
        {
          "name": "network_interface",
          "title": "Network Interface",
          "type": "string",
          "required": false,
          "description": "Network interface to use for the VM"
        }
      ]
    },
    {
      "name": "Delete VM",
      "app": "ansible",
      "playbook": "delete.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "vm_name",
          "title": "VM Name",
          "required": true,
          "type": "",
          "description": "Name of the VM to delete"
        }
      ]
    },
    {
      "name": "Manage VM",
      "app": "ansible",
      "playbook": "vm.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "vm_name",
          "title": "VM Name",
          "required": true,
          "type": "",
          "description": "Name of the VM to manage (supports partial matches)"
        },
        {
          "name": "desired_state",
          "title": "Desired State",
          "required": true,
          "type": "enum",
          "description": "Target VM state",
          "values": [
            { "name": "running", "value": "running" },
            { "name": "stopped", "value": "stopped" },
            { "name": "absent", "value": "absent" }
          ]
        }
      ]
    },
    {
      "name": "List VMs",
      "app": "ansible",
      "playbook": "list.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "vm_name",
          "title": "VM Name",
          "required": false,
          "type": "",
          "description": "Filter by VM name (supports partial matches; leave empty to list all)"
        }
      ]
    },
    {
      "name": "Pull Image",
      "app": "ansible",
      "playbook": "pull_image.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "remote_image_name",
          "title": "Remote Image Name",
          "required": true,
          "type": "",
          "description": "Name of the image to pull from the registry"
        }
      ]
    },
    {
      "name": "Install Engine",
      "app": "ansible",
      "playbook": "install_engine.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "orka_license_key",
          "title": "Orka License Key",
          "required": true,
          "type": "",
          "description": "License key for Orka Engine"
        },
        {
          "name": "engine_url",
          "title": "Engine URL",
          "default_value": "https://distribution.macstadium.com/orka-engine/official/3.5.2/orka-engine.pkg",
          "required": true,
          "type": "",
          "description": "URL to download the engine package"
        }
      ]
    },
    {
      "name": "Install Android SDK",
      "app": "ansible",
      "playbook": "install_android_sdk.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "install_android_sdk_force",
          "title": "Force Reinstall",
          "required": false,
          "type": "enum",
          "default_value": "false",
          "description": "Force reinstallation of the Android SDK even if already present",
          "values": [
            { "name": "No", "value": "false" },
            { "name": "Yes", "value": "true" }
          ]
        }
      ]
    },
    {
      "name": "Create Image",
      "app": "ansible",
      "playbook": "create_image.yml",
      "repository": "Local Playbooks",
      "inventory": "Dev Inventory",
      "environment": "Default",
      "survey_vars": [
        {
          "name": "remote_image_name",
          "title": "Remote Image Name",
          "required": true,
          "type": "string",
          "description": "OCI URL for the remote image"
        },
        {
          "name": "vm_image",
          "title": "VM Image",
          "required": true,
          "type": "string",
          "description": "Source image to create the VM from"
        }
      ]
    }
  ],
  "views": [],
  "integrations": [],
  "integration_aliases": [],
  "schedules": [],
  "secret_storages": [],
  "roles": []
}
